{
  "title": "ClawMatrix Fleet",
  "uid": "clawmatrix-fleet",
  "schemaVersion": 38,
  "version": 1,
  "refresh": "15s",
  "time": { "from": "now-1h", "to": "now" },
  "tags": ["clawmatrix"],
  "templating": {
    "list": [
      {
        "name": "registration",
        "label": "Registration",
        "type": "query",
        "datasource": { "type": "prometheus", "uid": "victoriametrics" },
        "query": "label_values(agent_health, registration)",
        "refresh": 2,
        "includeAll": true,
        "allValue": ".*",
        "multi": false,
        "sort": 1
      },
      {
        "name": "agent",
        "label": "Agent",
        "type": "query",
        "datasource": { "type": "prometheus", "uid": "victoriametrics" },
        "query": "label_values(agent_health{registration=~\"$registration\"}, agent)",
        "refresh": 2,
        "includeAll": true,
        "allValue": ".*",
        "multi": true,
        "sort": 1
      }
    ]
  },
  "panels": [
    {
      "id": 100,
      "title": "Agent Fleet",
      "type": "row",
      "collapsed": false,
      "gridPos": { "x": 0, "y": 0, "w": 24, "h": 1 }
    },
    {
      "id": 1,
      "title": "Healthy Agents",
      "type": "stat",
      "gridPos": { "x": 0, "y": 1, "w": 6, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "victoriametrics" },
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "textMode": "auto",
        "reduceOptions": { "calcs": ["lastNotNull"] }
      },
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": 0 },
              { "color": "green", "value": 1 }
            ]
          },
          "color": { "mode": "thresholds" }
        }
      },
      "targets": [
        {
          "expr": "count(agent_health{registration=~\"$registration\", agent=~\"$agent\"} == 1)",
          "legendFormat": "healthy"
        }
      ]
    },
    {
      "id": 2,
      "title": "Total Agents",
      "type": "stat",
      "gridPos": { "x": 6, "y": 1, "w": 6, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "victoriametrics" },
      "options": {
        "colorMode": "value",
        "graphMode": "none",
        "reduceOptions": { "calcs": ["lastNotNull"] }
      },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "fixed", "fixedColor": "blue" }
        }
      },
      "targets": [
        {
          "expr": "count(agent_health{registration=~\"$registration\", agent=~\"$agent\"})",
          "legendFormat": "total"
        }
      ]
    },
    {
      "id": 3,
      "title": "Requests Allowed (rate)",
      "type": "stat",
      "gridPos": { "x": 12, "y": 1, "w": 6, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "victoriametrics" },
      "options": {
        "colorMode": "value",
        "graphMode": "area",
        "reduceOptions": { "calcs": ["lastNotNull"] }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "color": { "mode": "fixed", "fixedColor": "green" }
        }
      },
      "targets": [
        {
          "expr": "sum(rate(agent_requests_allowed{registration=~\"$registration\", agent=~\"$agent\"}[5m]))",
          "legendFormat": "allowed/s"
        }
      ]
    },
    {
      "id": 4,
      "title": "Requests Blocked (rate)",
      "type": "stat",
      "gridPos": { "x": 18, "y": 1, "w": 6, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "victoriametrics" },
      "options": {
        "colorMode": "background",
        "graphMode": "area",
        "reduceOptions": { "calcs": ["lastNotNull"] }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": 0 },
              { "color": "red", "value": 0.01 }
            ]
          },
          "color": { "mode": "thresholds" }
        }
      },
      "targets": [
        {
          "expr": "sum(rate(agent_requests_blocked{registration=~\"$registration\", agent=~\"$agent\"}[5m]))",
          "legendFormat": "blocked/s"
        }
      ]
    },
    {
      "id": 5,
      "title": "Agent Health",
      "type": "table",
      "gridPos": { "x": 0, "y": 5, "w": 24, "h": 7 },
      "datasource": { "type": "prometheus", "uid": "victoriametrics" },
      "options": {
        "sortBy": [{ "displayName": "Health", "desc": true }],
        "footer": { "show": false }
      },
      "fieldConfig": {
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "Health" },
            "properties": [
              { "id": "custom.width", "value": 80 },
              {
                "id": "mappings",
                "value": [
                  { "type": "value", "options": { "1": { "text": "✓ healthy", "color": "green" }, "0": { "text": "✗ stale", "color": "red" } } }
                ]
              },
              { "id": "custom.displayMode", "value": "color-text" }
            ]
          },
          { "matcher": { "id": "byName", "options": "Time" }, "properties": [{ "id": "custom.hidden", "value": true }] },
          { "matcher": { "id": "byName", "options": "Value #Allowed" }, "properties": [{ "id": "displayName", "value": "Allowed" }, { "id": "unit", "value": "short" }] },
          { "matcher": { "id": "byName", "options": "Value #Blocked" }, "properties": [{ "id": "displayName", "value": "Blocked" }, { "id": "unit", "value": "short" }, { "id": "custom.displayMode", "value": "color-text" }, { "id": "thresholds", "value": { "mode": "absolute", "steps": [{ "color": "green", "value": 0 }, { "color": "red", "value": 1 }] } } ] },
          { "matcher": { "id": "byName", "options": "Value #AvgMs" }, "properties": [{ "id": "displayName", "value": "Avg Latency" }, { "id": "unit", "value": "ms" }] }
        ]
      },
      "transformations": [
        { "id": "merge", "options": {} },
        {
          "id": "organize",
          "options": {
            "renameByName": {
              "agent": "Agent",
              "registration": "Registration",
              "Value #Health": "Health"
            }
          }
        }
      ],
      "targets": [
        {
          "expr": "agent_health{registration=~\"$registration\", agent=~\"$agent\"}",
          "legendFormat": "{{agent}}",
          "instant": true,
          "refId": "Health",
          "format": "table"
        },
        {
          "expr": "agent_requests_allowed{registration=~\"$registration\", agent=~\"$agent\"}",
          "instant": true,
          "refId": "Allowed",
          "format": "table"
        },
        {
          "expr": "agent_requests_blocked{registration=~\"$registration\", agent=~\"$agent\"}",
          "instant": true,
          "refId": "Blocked",
          "format": "table"
        },
        {
          "expr": "agent_latency_avg_ms_milliseconds{registration=~\"$registration\", agent=~\"$agent\"}",
          "instant": true,
          "refId": "AvgMs",
          "format": "table"
        }
      ]
    },
    {
      "id": 6,
      "title": "Request Traffic — Allowed vs Blocked",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 12, "w": 16, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "victoriametrics" },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": { "lineWidth": 2, "fillOpacity": 10 }
        },
        "overrides": [
          { "matcher": { "id": "byFrameRefID", "options": "Blocked" }, "properties": [{ "id": "color", "value": { "fixedColor": "red", "mode": "fixed" } }] },
          { "matcher": { "id": "byFrameRefID", "options": "Allowed" }, "properties": [{ "id": "color", "value": { "fixedColor": "green", "mode": "fixed" } }] }
        ]
      },
      "targets": [
        {
          "expr": "sum by (agent) (rate(agent_requests_allowed{registration=~\"$registration\", agent=~\"$agent\"}[1m]))",
          "legendFormat": "allowed — {{agent}}",
          "refId": "Allowed"
        },
        {
          "expr": "sum by (agent) (rate(agent_requests_blocked{registration=~\"$registration\", agent=~\"$agent\"}[1m]))",
          "legendFormat": "blocked — {{agent}}",
          "refId": "Blocked"
        }
      ]
    },
    {
      "id": 7,
      "title": "Avg Latency by Agent",
      "type": "timeseries",
      "gridPos": { "x": 16, "y": 12, "w": 8, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "victoriametrics" },
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
          "custom": { "lineWidth": 2, "fillOpacity": 5 }
        }
      },
      "targets": [
        {
          "expr": "agent_latency_avg_ms_milliseconds{registration=~\"$registration\", agent=~\"$agent\"}",
          "legendFormat": "{{agent}}"
        }
      ]
    },
    {
      "id": 8,
      "title": "Cumulative Requests per Agent",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 20, "w": 24, "h": 7 },
      "datasource": { "type": "prometheus", "uid": "victoriametrics" },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": { "lineWidth": 2, "fillOpacity": 8 }
        }
      },
      "targets": [
        {
          "expr": "agent_requests_total{registration=~\"$registration\", agent=~\"$agent\"}",
          "legendFormat": "{{agent}}"
        }
      ]
    },

    {
      "id": 200,
      "title": "System / Control Plane",
      "type": "row",
      "collapsed": false,
      "gridPos": { "x": 0, "y": 27, "w": 24, "h": 1 }
    },
    {
      "id": 11,
      "title": "Users",
      "type": "stat",
      "gridPos": { "x": 0, "y": 28, "w": 4, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "victoriametrics" },
      "options": {
        "colorMode": "value",
        "graphMode": "none",
        "reduceOptions": { "calcs": ["lastNotNull"] }
      },
      "fieldConfig": {
        "defaults": { "color": { "mode": "fixed", "fixedColor": "blue" } }
      },
      "targets": [
        { "expr": "cp_users_total", "legendFormat": "users" }
      ]
    },
    {
      "id": 12,
      "title": "Active Registrations",
      "type": "stat",
      "gridPos": { "x": 4, "y": 28, "w": 4, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "victoriametrics" },
      "options": {
        "colorMode": "value",
        "graphMode": "none",
        "reduceOptions": { "calcs": ["lastNotNull"] }
      },
      "fieldConfig": {
        "defaults": { "color": { "mode": "fixed", "fixedColor": "green" } }
      },
      "targets": [
        { "expr": "cp_registrations_total{status=\"active\"}", "legendFormat": "active" }
      ]
    },
    {
      "id": 13,
      "title": "Archived Registrations",
      "type": "stat",
      "gridPos": { "x": 8, "y": 28, "w": 4, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "victoriametrics" },
      "options": {
        "colorMode": "value",
        "graphMode": "none",
        "reduceOptions": { "calcs": ["lastNotNull"] }
      },
      "fieldConfig": {
        "defaults": { "color": { "mode": "fixed", "fixedColor": "orange" } }
      },
      "targets": [
        { "expr": "cp_registrations_total{status=\"archived\"}", "legendFormat": "archived" }
      ]
    },
    {
      "id": 14,
      "title": "HTTP Request Rate",
      "type": "stat",
      "gridPos": { "x": 12, "y": 28, "w": 6, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "victoriametrics" },
      "options": {
        "colorMode": "value",
        "graphMode": "area",
        "reduceOptions": { "calcs": ["lastNotNull"] }
      },
      "fieldConfig": {
        "defaults": { "unit": "reqps", "color": { "mode": "fixed", "fixedColor": "purple" } }
      },
      "targets": [
        { "expr": "sum(rate(cp_http_requests_total[5m]))", "legendFormat": "req/s" }
      ]
    },
    {
      "id": 15,
      "title": "HTTP Error Rate",
      "type": "stat",
      "gridPos": { "x": 18, "y": 28, "w": 6, "h": 4 },
      "datasource": { "type": "prometheus", "uid": "victoriametrics" },
      "options": {
        "colorMode": "background",
        "graphMode": "area",
        "reduceOptions": { "calcs": ["lastNotNull"] }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": 0 },
              { "color": "red", "value": 0.01 }
            ]
          },
          "color": { "mode": "thresholds" }
        }
      },
      "targets": [
        { "expr": "sum(rate(cp_http_requests_total{status_code=~\"5..\"}[5m]))", "legendFormat": "5xx/s" }
      ]
    },
    {
      "id": 16,
      "title": "HTTP Requests by Status",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 32, "w": 12, "h": 7 },
      "datasource": { "type": "prometheus", "uid": "victoriametrics" },
      "fieldConfig": {
        "defaults": { "unit": "reqps", "custom": { "lineWidth": 2, "fillOpacity": 8 } }
      },
      "targets": [
        {
          "expr": "sum by (status_code) (rate(cp_http_requests_total[1m]))",
          "legendFormat": "{{status_code}}"
        }
      ]
    },
    {
      "id": 17,
      "title": "HTTP P95 Latency",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 32, "w": 12, "h": 7 },
      "datasource": { "type": "prometheus", "uid": "victoriametrics" },
      "fieldConfig": {
        "defaults": { "unit": "ms", "custom": { "lineWidth": 2, "fillOpacity": 5 } }
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum by (le) (rate(cp_http_request_duration_ms_bucket[5m])))",
          "legendFormat": "p95"
        },
        {
          "expr": "histogram_quantile(0.50, sum by (le) (rate(cp_http_request_duration_ms_bucket[5m])))",
          "legendFormat": "p50"
        }
      ]
    },
    {
      "id": 9,
      "title": "Go Runtime",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 39, "w": 24, "h": 7 },
      "datasource": { "type": "prometheus", "uid": "victoriametrics" },
      "fieldConfig": {
        "defaults": {
          "custom": { "lineWidth": 1 }
        },
        "overrides": [
          { "matcher": { "id": "byName", "options": "heap alloc" }, "properties": [{ "id": "unit", "value": "bytes" }] },
          { "matcher": { "id": "byName", "options": "goroutines" }, "properties": [{ "id": "unit", "value": "short" }, { "id": "custom.axisPlacement", "value": "right" }] }
        ]
      },
      "targets": [
        { "expr": "go_memstats_heap_alloc_bytes", "legendFormat": "heap alloc" },
        { "expr": "go_goroutines", "legendFormat": "goroutines" }
      ]
    }
  ]
}
