FROM alpine:3.21
RUN apk add --no-cache ca-certificates iptables
COPY bin/clutch /usr/local/bin/clutch
COPY bin/picoclaw /usr/local/bin/picoclaw
COPY config/picoclaw.json /root/.picoclaw/config.json
COPY entrypoint.sh /entrypoint.sh
RUN chmod +x /usr/local/bin/clutch /usr/local/bin/picoclaw /entrypoint.sh
EXPOSE 8080
ENTRYPOINT ["/entrypoint.sh"]
CMD ["--listen", "0.0.0.0:8080"]
