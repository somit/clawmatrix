FROM alpine:3.21
RUN apk add --no-cache ca-certificates wget
COPY bin/control-plane /usr/local/bin/control-plane
COPY config/bootstrap.json /etc/control-plane/bootstrap.json
COPY entrypoint-cp.sh /entrypoint-cp.sh
RUN chmod +x /usr/local/bin/control-plane /entrypoint-cp.sh
VOLUME /data
EXPOSE 8080
ENTRYPOINT ["/entrypoint-cp.sh"]
