{
  "models": {
    "mode": "merge",
    "providers": {
      "anthropic": {
        "baseUrl": "https://api.anthropic.com",
        "models": [
          {
            "id": "claude-sonnet-4-20250514",
            "name": "Claude Sonnet 4",
            "reasoning": true,
            "input": ["text"],
            "cost": { "input": 3, "output": 15, "cacheRead": 0.3, "cacheWrite": 3.75 },
            "contextWindow": 200000,
            "maxTokens": 8192
          }
        ]
      }
    }
  },
  "agents": {
    "defaults": {
      "models": {
        "anthropic/claude-sonnet-4-20250514": {}
      },
      "model": { "primary": "anthropic/claude-sonnet-4-20250514" },
      "compaction": { "mode": "safeguard" },
      "maxConcurrent": 2,
      "subagents": { "maxConcurrent": 4 },
      "heartbeat": { "every": "0m" }
    },
    "list": [
      {
        "id": "cto-id",
        "name": "cto",
        "default": true,
        "workspace": "/workspace/cto",
        "identity": { "name": "CTO", "theme": "Tech leadership" },
        "subagents": { "allowAgents": ["techlead"] }
      },
      {
        "id": "techlead-id",
        "name": "techlead",
        "workspace": "/workspace/techlead",
        "identity": { "name": "Tech Lead", "theme": "Senior engineering specialist" }
      }
    ]
  },
  "tools": {
    "agentToAgent": {
      "enabled": true,
      "allow": ["cto-id", "techlead-id"]
    },
    "web": {
      "fetch": { "enabled": true },
      "search": { "enabled": true, "provider": "brave" }
    }
  },
  "browser": {
    "noSandbox": true,
    "executablePath": "/usr/bin/chromium-browser"
  },
  "channels": {},
  "gateway": {
    "mode": "local",
    "port": 18789,
    "bind": "loopback",
    "auth": { "mode": "none" }
  }
}
